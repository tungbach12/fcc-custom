# FCC Custom - Environment Configuration
# Copy this file to ~/.fcc/.env and fill in your values

# =====================
# NVIDIA NIM API Keys
# =====================
# Get free API key at: https://build.nvidia.com/settings/api-keys
# You can use up to 3 keys for rate-limit fallback

# Primary key (required)
NVIDIA_NIM_API_KEY=nvapi-your-primary-key-here

# Fallback keys (optional)
NVIDIA_NIM_FALLBACK_API_KEY=
NVIDIA_NIM_2ND_FALLBACK_API_KEY=

# =====================
# NIM Settings
# =====================
# Rotate to next key after N requests (0 = disabled, default: 20)
NIM_PROACTIVE_ROTATE_AFTER=20

# =====================
# Other Providers (optional)
# =====================
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# OPENAI_API_KEY=

# =====================
# Server Settings
# =====================
# AUTH_TOKEN=freecc
# SERVER_PORT=8082
